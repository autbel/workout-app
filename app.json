{
  "expo": {
    "name": "筋トレ日記",
    "slug": "workout-app",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "workoutapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a2540"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.personal.kintorenikki"
    },
    "android": {
      "package": "com.personal.kintorenikki",
      "versionCode": 18,
      "adaptiveIcon": {
        "backgroundColor": "#1a2540",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withAndroidKeyboard",
      "expo-notifications",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "005a024e-a6d9-45b3-b424-af856812a725"
      }
    },
    "owner": "autbel",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/005a024e-a6d9-45b3-b424-af856812a725"
    }
  }
}
